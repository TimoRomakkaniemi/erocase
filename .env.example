# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SendGrid (same as Trusty_uusi: transactional email from the app)
# Without SENDGRID_API_KEY, sendMail() and POST /api/email/send do not deliver.
SENDGRID_API_KEY=
# Verified sender in SendGrid (Trusty uses SENDER_EMAIL; SENDGRID_FROM_EMAIL is supported too)
SENDER_EMAIL=
# SENDGRID_FROM_EMAIL=

# Optional: Bearer token for POST /api/email/send to arbitrary recipients (cron, scripts).
# If unset, only logged-in users can POST, and only to their own email.
# EMAIL_INTERNAL_SECRET=

# Demo user (payment bypass) — see scripts/README.md
# DEMO_USER_EMAIL=
# DEMO_USER_PASSWORD=
